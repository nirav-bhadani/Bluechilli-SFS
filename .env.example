# Copy to .env.local and fill in. Never commit real keys.

# Toggles whether the chat hits the real AI route (true) or the mock agent (false).
NEXT_PUBLIC_USE_REAL_AI=false

# Server-only. Used by /app/api/chat/route.ts. NEVER expose to the browser.
# Get a key from https://openrouter.ai/keys (starts with sk-or-v1-).
OPENROUTER_API_KEY=

# Optional model override for the chat API route.
# Demo default is the cheap, agentic deepseek/deepseek-v4-flash.
# Alternative: openai/gpt-5.4-mini
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
